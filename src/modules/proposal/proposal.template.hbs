<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Proposta {{numero_proposta}}</title>
  <style>{{inlineCss}}</style>
</head>
<body>
  <div class="page">
    <header class="header">
      <div class="logos">
        <img class="logo-ghtec" src="{{logo_ghtec}}" alt="GHTec" />
        {{#if logo_parceira}}<img class="logo-parceira" src="{{logo_parceira}}" alt="Parceira" />{{/if}}
      </div>
    </header>

    <main class="content">
      <h1>PROPOSTA COMERCIAL Nº {{numero_proposta}}</h1>
      <div class="title-divider"></div>

      <section class="section two-col">
        <div>
          <h2>CLIENTE</h2>
          <p><strong>{{cliente.nome}}</strong></p>
          {{#if cliente.razao_social}}<p>{{cliente.razao_social}}</p>{{/if}}
          {{#if cliente.cnpj}}<p>CNPJ: {{cliente.cnpj}}</p>{{/if}}
          {{#if cliente.endereco}}<p>{{cliente.endereco}}</p>{{/if}}
          {{#if cliente.cidade}}<p>{{cliente.cidade}}{{#if cliente.estado}} - {{cliente.estado}}{{/if}}</p>{{else}}{{#if cliente.estado}}<p>{{cliente.estado}}</p>{{/if}}{{/if}}
          {{#if cliente.cep}}<p>CEP: {{cliente.cep}}</p>{{/if}}
          {{#if cliente.email}}<p>E-mail: {{cliente.email}}</p>{{/if}}
        </div>

        <div>
          <h2>DATA</h2>
          <p>{{data_emissao}}</p>
        </div>
      </section>

      <section class="section">
        <h2>APRESENTAÇÃO</h2>
        <p>A GHTec Manutenção e Vendas de Equipamentos Hospitalares Ltda apresenta sua proposta comercial para fornecimento de peças e/ou prestação de serviços técnicos em equipamentos hospitalares, conforme descrição dos itens, valores e condições comerciais abaixo.</p>
      </section>

      <section class="section section-objeto">
        <h2>OBJETO</h2>
        <p>{{objeto_proposta}}</p>
      </section>

      <section class="section section-items">
        <h2>DESCRIÇÃO DOS ITENS</h2>

        <table>
          <colgroup>
            <col style="width: 8%">
            <col style="width: 7%">
            <col style="width: 33%">
            <col style="width: 20%">
            <col style="width: 18%">
            <col style="width: 14%">
          </colgroup>
          <thead>
            <tr>
              <th class="col-center">ITEM</th>
              <th class="col-center">QTD</th>
              <th class="col-center">DESCRIÇÃO</th>
              <th class="col-center">VALOR UNITÁRIO</th>
              <th class="col-center">SUBTOTAL</th>
              <th class="col-center">NCM</th>
            </tr>
          </thead>
          <tbody>
            {{#each itens}}
              <tr>
                <td class="col-center">{{item_label}}</td>
                <td class="col-center">{{quantidade}}</td>
                <td class="col-center">{{descricao}}</td>
                <td class="col-center">{{valor_unitario}}</td>
                <td class="col-center">{{subtotal}}</td>
                <td class="col-center">{{ncm}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>

        <div class="total-box">
          <div class="total-label">TOTAL</div>
          <div class="total-right">
            <div class="total-value">{{valor_total}}</div>
            <div class="total-extenso">{{valor_total_extenso}}</div>
          </div>
        </div>
      </section>

      <section class="section">
        <h2>CONDIÇÕES COMERCIAIS</h2>
        <ul class="conditions">
          <li><strong>Forma de pagamento:</strong> {{condicoes.forma_pagamento}}</li>
          <li><strong>Prazo de pagamento:</strong> {{condicoes.prazo_pagamento}}</li>
          <li><strong>Prazo de entrega:</strong> {{condicoes.prazo_entrega}}</li>
          {{#if condicoes.garantia}}<li><strong>Garantia:</strong> {{condicoes.garantia}}</li>{{/if}}
          <li><strong>Validade da proposta:</strong> {{condicoes.validade}}</li>
        </ul>
      </section>

      {{#if observacoes}}
      <section class="section">
        <h2>OBSERVAÇÕES</h2>
        <p>{{observacoes}}</p>
      </section>
      {{/if}}

      <section class="section">
        <p>Permanecemos à disposição para quaisquer esclarecimentos.</p>
      </section>

      <section class="signature">
        <p><strong>{{responsavel.nome}}</strong></p>
        <p>{{responsavel.cargo}}</p>
        <p>{{responsavel.telefone}}</p>
      </section>
    </main>

    <footer class="page-footer">
      <p>GHTec Manutenção e Vendas de Equipamentos Hospitalares Ltda</p>
      <p>CNPJ: 40.135.233/0001-16 · IE: 0039229140040</p>
      <p>Rua Confrade Machado, 400 - Nova Esperança</p>
      <p>ghteccompras@gmail.com · ghtecmg.com.br</p>
    </footer>
  </div>
</body>
</html>
