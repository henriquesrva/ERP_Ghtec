# ─────────────────────────────────────────────────────────────
# GHTec Propostas — modelo de configuração de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NÃO deve ser commitado no git.
# ─────────────────────────────────────────────────────────────

# Segredo usado para assinar os cookies de sessão.
# OBRIGATÓRIO em produção. Use um valor longo e aleatório (mínimo 32 chars).
# Para gerar: node -e "require('crypto').randomBytes(32).toString('hex')|xargs echo"
SESSION_SECRET=troque-por-um-valor-secreto-longo-e-aleatorio

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente de execução: development | production
NODE_ENV=development
