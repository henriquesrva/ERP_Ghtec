# ─────────────────────────────────────────────────────────────
# GHTec Propostas — modelo de configuração de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NÃO deve ser commitado no git.
# ─────────────────────────────────────────────────────────────

# Segredo usado para assinar os cookies de sessão.
# OBRIGATÓRIO em produção. Use um valor longo e aleatório (mínimo 32 chars).
# Para gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=troque-por-um-valor-secreto-longo-e-aleatorio

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente de execução: development | production
NODE_ENV=development

# ─── PostgreSQL / Prisma ──────────────────────────────────────────────────────
# Banco de dados principal da aplicação.
# Usado pelo Prisma Client em runtime e pelo CLI do Prisma (migrate, studio).
# Desenvolvimento local: docker compose up -d postgres (ver docker-compose.yml)
# Produção: substituir por URL do banco provisionado.
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
DATABASE_URL="postgresql://ghtec:ghtec123@localhost:5432/ghtec_propostas"
